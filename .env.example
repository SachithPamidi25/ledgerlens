# Copy this file to .env and fill in all values before running locally.
# .env is gitignored — never commit real secrets.

# Database
POSTGRES_DB=ledgerlens
POSTGRES_USER=
POSTGRES_PASSWORD=
DB_URL=jdbc:postgresql://localhost:5432/ledgerlens
DB_USERNAME=
DB_PASSWORD=

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=ledgerlens-receipts

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Local load testing
RATE_LIMIT_IP_MAX_REQUESTS_PER_MINUTE=200
RATE_LIMIT_IP_TRUST_PROXY_HEADERS=false

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
